{ 
  "cosmos-installer": {
    "form": [
      {
        "name": "adminOnly",
        "label": "Do you want to make this service admin only?",
        "initialValue": true,
        "type": "checkbox"
      }
    ],
    "translation": {
      "de": {
        "form.adminOnly.label": "Möchten Sie diesen Dienst nur für Administratoren zugänglich machen?"
      },
      "fr": {
        "form.adminOnly.label": "Souhaitez-vous rendre ce service accessible uniquement aux administrateurs ?"
      },
      "it": {
        "form.adminOnly.label": "Desideri rendere questo servizio accessibile solo agli amministratori?"
      }
    }
  },
  "minVersion": "0.22.4",
  "services": {
    "{ServiceName}": {
      "image": "influxdb:3-core",
      "container_name": "{ServiceName}",
      "restart": "unless-stopped",
      "UID": 1000,
      "GID": 1000,
      "security_opt": [
        "no-new-privileges:true"
      ],
      "environment": [
        "PUID=1000",
        "PGID=1000",
        "INFLUXDB3_NODE_IDENTIFIER_PREFIX=node0",
        "INFLUXDB3_OBJECT_STORE=file",
        "INFLUXDB3_DB_DIR=/var/lib/influxdb3/data",
        "INFLUXDB3_PLUGIN_DIR=/var/lib/influxdb3/plugins",
        "INFLUXDB3_START_WITHOUT_AUTH=false"
      ],
      "labels": {
        "cosmos-force-network-secured": "true",
        "cosmos-auto-update": "true",
        "cosmos-icon": "https://aseracorp.github.io/resiSTORE/servapps/InfluxDB/icon.png",
        "cosmos-stack": "influxdb",
        "cosmos-stack-main": "influxdb"
      },
      "volumes": [
        {
          "source": "{ServiceName}-data",
          "target": "/var/lib/influxdb3",
          "type": "volume"
        }
      ],
      "post_install": [
        "influxdb3 create token --admin | grep Token | sed 's/^.\\{7\\}//' > /var/lib/influxdb3/token && influxdb3 create database --retention-period 30d default --token $(cat /var/lib/influxdb3/token)"
      ]
    },
    "{ServiceName}-explorer": {
      "image": "influxdata/influxdb3-ui:latest",
      "container_name": "{ServiceName}-explorer",
      "restart": "unless-stopped",
      "UID": 1000,
      "GID": 1000,
      "depends_on": {
        "InfluxDB": {}
      },
      "security_opt": [
        "no-new-privileges:true"
      ],
      "environment": [
        "PUID=1000",
        "PGID=1000",
        "DEFAULT_INFLUX_SERVER=http://influxdb:8181",
        "DEFAULT_API_TOKEN=\"\"",
        "DEFAULT_INFLUX_DATABASE=default",
        "DEFAULT_SERVER_NAME=\"Local InfluxDB 3\""
      ],
      "labels": {
        "cosmos-force-network-secured": "true",
        "cosmos-auto-update": "true",
        "cosmos-icon": "https://aseracorp.github.io/resiSTORE/servapps/InfluxDB/icon.png",
        "cosmos-stack": "influxdb",
        "cosmos-stack-main": "influxdb"
      },
      "volumes": [
        {
          "source": "{ServiceName}-explorer-db",
          "target": "/db",
          "type": "volume"
        },
        {
          "source": "{ServiceName}-explorer-config",
          "target": "/app-root/config",
          "type": "volume"
        },
        {
          "type": "volume",
          "source": "{ServiceName}-explorer-ssl",
          "target": "/etc/nginx/ssl"
        },
        {
          "type": "volume",
          "source": "{ServiceName}-explorer-admininstructions",
          "target": "/app-root/admin-instructions"
        },
        {
          "type": "volume",
          "source": "{ServiceName}-explorer-cacerts",
          "target": "/ca-certs"
        },
        {
          "source": "{ServiceName}-data",
          "target": "/var/lib/influxdb3",
          "type": "volume"
        }
      ],
      "post_install": [
        "wget -O config/config.json https://aseracorp.github.io/resiSTORE/servapps/InfluxDB/artefacts/config.json && apk update && apk add yq && TOKEN=$(cat /var/lib/influxdb3/token) && yq -i '.DEFAULT_API_TOKEN = env(TOKEN)' config/config.json"
      ],
      "routes": [
        {
          "name": "{ServiceName}-explorer",
          "description": "{ServiceName}-explorer im Netzwerk veröffentlichen",
          "useHost": true,
          "target": "http://{ServiceName}:80",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "SmartShield": {
            "Enabled": true
          },
          "AuthEnabled": true
          {if Context.adminOnly}
           , "AuthAdmin": true
          {/if}
        }
      ]
    }
  }
}