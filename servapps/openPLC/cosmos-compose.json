{ 
  "cosmos-installer": {
  },
  "minVersion": "0.22.4",
  "services": {
    "{ServiceName}": {
      "image": "ghcr.io/autonomy-logic/openplc-runtime:latest",
      "container_name": "{ServiceName}",
      "restart": "unless-stopped",
      "cap_drop": [
        "ALL"
      ],
      "cap_add": [
        "SYS_NICE",
        "SYS_RESOURCE"
      ],
      "labels": {
        "cosmos-force-network-secured": "true",
        "cosmos-auto-update": "true",
        "cosmos-icon": "https://aseracorp.github.io/resiSTORE/servapps/openPLC/icon.png"
      },
      "volumes": [
        {
          "source": "{ServiceName}-data",
          "target": "/var/run/runtime",
          "type": "volume"
        }
      ],
      "routes": [
        {
          "name": "{ServiceName}",
          "description": "{ServiceName} im Netzwerk veröffentlichen",
          "useHost": true,
          "host": "0.0.0.0:8443",
          "target": "tcp://{ServiceName}:8443",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "SmartShield": {
            "Enabled": true
          }
        }
      ]
    }
  }
}